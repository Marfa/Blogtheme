<header class="post__header">
  {{#if feature_image}}
    <img
      class="post__feature-image"
      src="{{img_url feature_image size="l"}}"
      alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
    >
  {{/if}}
  <div class="post__info">
    <h1 class="post__title">{{title}}</h1>
    <span class="post__meta">
      <time datetime="{{date published_at format="DD MMMM YYYY"}}" class="post__date">{{date published_at format="DD MMMM YYYY"}}</time><span class="post__author">{{authors}}</span>
    </span>
  </div>
</header>
