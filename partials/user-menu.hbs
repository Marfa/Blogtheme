<div class="user-menu js-user-menu">
    {{!-- Member Links --}}
    {{#if @member}}
        <div class="member-user">
            <div class="member-info flex flex-col">
                <div class="member-name">{{@member.name}}</div>
                <span class="member-email">{{@member.email}}</span>
            </div>
        </div>

        <a class="account-link" href="/#/portal/account" tabindex="0"
           title="{{t "Account"}}" aria-label="{{t "Account"}}">
            {{>icon name="user" size="xs"}}{{t "Account"}}
        </a>

        <a class="signout-link" href="#signout" tabindex="0"
           title="{{t "Выйти"}}" aria-label="{{t "Выйти"}}"
           data-members-signout>
            {{>icon name="log-out" size="xs"}}{{t "Выйти"}}
        </a>
    {{else}}
        {{!-- Sign up / Sign in hidden on mobile and desktop --}}
    {{/if}}

    {{!-- Dark/Light Theme --}}
    <button class="btn--toggle btn-theme-toggle js-theme-toggle" tabindex="0"
            title="{{t "Theme Toggle"}}" aria-label="{{t "Theme Toggle"}}"
            onclick="toggleTheme()">
        {{>icon name="moon" size="xs"}}
        {{>icon name="sun" size="xs"}}
        <span>{{t "Сменить тему"}}</span>
    </button>
</div>